# =============================================================
#  UPS Manager - Variables de Entorno
#  Copia este archivo como .env y ajusta los valores
# =============================================================

# --- DNS / Red ---
APP_DOMAIN=lbs.local
APP_HOST=0.0.0.0
APP_PORT=5000

# --- mDNS (Bonjour / Zeroconf) ---
MDNS_ENABLED=true
MDNS_SERVICE_NAME=UPS Manager LBS

# --- Base de datos ---
DATABASE_URL=postgresql://usuario:CONTRASEÑA@localhost:5432/ups_manager

# --- Flask ---
FLASK_CONFIG=development
SECRET_KEY=

# --- InfluxDB (monitoreo) ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-token
INFLUXDB_ORG=my-org
INFLUXDB_BUCKET=ups_monitoring

# --- CORS (dejar vacio para auto-configurar con APP_DOMAIN) ---
CORS_ORIGINS=
